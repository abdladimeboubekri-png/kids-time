<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d0f1a"
    android:padding="40dp"
    android:gravity="center">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📺 KidTime Lock"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        android:text="Pick your name and enter your PIN"
        android:textColor="#7a82a8"
        android:textSize="18sp" />

    <!-- Kid selector -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/kid1"
            android:layout_width="160dp"
            android:layout_height="100dp"
            android:layout_margin="6dp"
            android:background="@drawable/btn_kid"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/kid2"
            android:layout_width="160dp"
            android:layout_height="100dp"
            android:layout_margin="6dp"
            android:background="@drawable/btn_kid"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/kid3"
            android:layout_width="160dp"
            android:layout_height="100dp"
            android:layout_margin="6dp"
            android:background="@drawable/btn_kid"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- PIN dots -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <TextView android:id="@+id/dot1" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="○" android:textColor="#4d96ff" android:textSize="42sp" android:layout_margin="6dp"/>
        <TextView android:id="@+id/dot2" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="○" android:textColor="#4d96ff" android:textSize="42sp" android:layout_margin="6dp"/>
        <TextView android:id="@+id/dot3" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="○" android:textColor="#4d96ff" android:textSize="42sp" android:layout_margin="6dp"/>
        <TextView android:id="@+id/dot4" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="○" android:textColor="#4d96ff" android:textSize="42sp" android:layout_margin="6dp"/>
    </LinearLayout>

    <!-- Numpad -->
    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4">

        <Button android:id="@+id/n1" android:layout_width="80dp" android:layout_height="80dp"
            android:layout_margin="6dp" android:text="1" android:textSize="22sp" android:textStyle="bold"
            android:background="@drawable/btn_num" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/n2" android:layout_width="80dp" android:layout_height="80dp"
            android:layout_margin="6dp" android:text="2" android:textSize="22sp" android:textStyle="bold"
            android:background="@drawable/btn_num" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/n3" android:layout_width="80dp" android:layout_height="80dp"
            android:layout_margin="6dp" android:text="3" android:textSize="22sp" android:textStyle="bold"
            android:background="@drawable/btn_num" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/n4" android:layout_width="80dp" android:layout_height="80dp"
            android:layout_margin="6dp" android:text="4" android:textSize="22sp" android:textStyle="bold"
            android:background="@drawable/btn_num" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/n5" android:layout_width="80dp" android:layout_height="80dp"
            android:layout_margin="6dp" android:text="5" android:textSize="22sp" android:textStyle="bold"
            android:background="@drawable/btn_num" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/n6" android:layout_width="80dp" android:layout_height="80dp"
            android:layout_margin="6dp" android:text="6" android:textSize="22sp" android:textStyle="bold"
            android:background="@drawable/btn_num" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/n7" android:layout_width="80dp" android:layout_height="80dp"
            android:layout_margin="6dp" android:text="7" android:textSize="22sp" android:textStyle="bold"
            android:background="@drawable/btn_num" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/n8" android:layout_width="80dp" android:layout_height="80dp"
            android:layout_margin="6dp" android:text="8" android:textSize="22sp" android:textStyle="bold"
            android:background="@drawable/btn_num" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/n9" android:layout_width="80dp" android:layout_height="80dp"
            android:layout_margin="6dp" android:text="9" android:textSize="22sp" android:textStyle="bold"
            android:background="@drawable/btn_num" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/exit" android:layout_width="80dp" android:layout_height="80dp"
            android:layout_margin="6dp" android:text="Exit" android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/btn_num" android:textColor="#ff6b6b"/>
        <Button android:id="@+id/n0" android:layout_width="80dp" android:layout_height="80dp"
            android:layout_margin="6dp" android:text="0" android:textSize="22sp" android:textStyle="bold"
            android:background="@drawable/btn_num" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/del" android:layout_width="80dp" android:layout_height="80dp"
            android:layout_margin="6dp" android:text="⌫" android:textSize="22sp" android:textStyle="bold"
            android:background="@drawable/btn_num" android:textColor="#FFFFFF"/>
    </GridLayout>

</LinearLayout>
