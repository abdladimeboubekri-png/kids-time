<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d0f1a"
    android:padding="32dp"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="📺 KidTime"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pick your name"
            android:textColor="#7a82a8"
            android:textSize="16sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#4d96ff"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- LEFT: numpad -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/row0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="6dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/row_normal">
                <TextView android:id="@+id/r0c0" android:layout_width="78dp" android:layout_height="64dp"
                    android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_margin="4dp"
                    android:background="@drawable/cell_normal"/>
                <TextView android:id="@+id/r0c1" android:layout_width="78dp" android:layout_height="64dp"
                    android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_margin="4dp"
                    android:background="@drawable/cell_normal"/>
                <TextView android:id="@+id/r0c2" android:layout_width="78dp" android:layout_height="64dp"
                    android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_margin="4dp"
                    android:background="@drawable/cell_normal"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="6dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/row_normal">
                <TextView android:id="@+id/r1c0" android:layout_width="78dp" android:layout_height="64dp"
                    android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_margin="4dp"
                    android:background="@drawable/cell_normal"/>
                <TextView android:id="@+id/r1c1" android:layout_width="78dp" android:layout_height="64dp"
                    android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_margin="4dp"
                    android:background="@drawable/cell_normal"/>
                <TextView android:id="@+id/r1c2" android:layout_width="78dp" android:layout_height="64dp"
                    android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_margin="4dp"
                    android:background="@drawable/cell_normal"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="6dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/row_normal">
                <TextView android:id="@+id/r2c0" android:layout_width="78dp" android:layout_height="64dp"
                    android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_margin="4dp"
                    android:background="@drawable/cell_normal"/>
                <TextView android:id="@+id/r2c1" android:layout_width="78dp" android:layout_height="64dp"
                    android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_margin="4dp"
                    android:background="@drawable/cell_normal"/>
                <TextView android:id="@+id/r2c2" android:layout_width="78dp" android:layout_height="64dp"
                    android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_margin="4dp"
                    android:background="@drawable/cell_normal"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="6dp"
                android:background="@drawable/row_normal">
                <TextView android:id="@+id/r3c0" android:layout_width="78dp" android:layout_height="64dp"
                    android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                    android:textColor="#ff6b6b" android:layout_margin="4dp"
                    android:background="@drawable/cell_normal"/>
                <TextView android:id="@+id/r3c1" android:layout_width="78dp" android:layout_height="64dp"
                    android:gravity="center" android:textSize="24sp" android:textStyle="bold"
                    android:textColor="#FFFFFF" android:layout_margin="4dp"
                    android:background="@drawable/cell_normal"/>
                <TextView android:id="@+id/r3c2" android:layout_width="78dp" android:layout_height="64dp"
                    android:gravity="center" android:textSize="22sp" android:textStyle="bold"
                    android:textColor="#ffd93d" android:layout_margin="4dp"
                    android:background="@drawable/cell_normal"/>
            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#1e2235"
            android:layout_marginHorizontal="20dp"/>

        <!-- RIGHT: kids list + PIN dots -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WHO IS WATCHING?"
                android:textColor="#7a82a8"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"/>

            <ScrollView
                android:id="@+id/kidsScrollView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="none"
                android:descendantFocusability="blocksDescendants"
                android:focusable="false">

                <LinearLayout
                    android:id="@+id/kidsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingHorizontal="16dp"/>
            </ScrollView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <TextView android:id="@+id/dot1" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="○" android:textColor="#4d96ff" android:textSize="36sp" android:layout_margin="6dp"/>
                <TextView android:id="@+id/dot2" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="○" android:textColor="#4d96ff" android:textSize="36sp" android:layout_margin="6dp"/>
                <TextView android:id="@+id/dot3" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="○" android:textColor="#4d96ff" android:textSize="36sp" android:layout_margin="6dp"/>
                <TextView android:id="@+id/dot4" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="○" android:textColor="#4d96ff" android:textSize="36sp" android:layout_margin="6dp"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>
