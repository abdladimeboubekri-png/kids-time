<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d0f1a"
    android:padding="40dp"
    android:gravity="center">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📺 KidTime — Enter PIN"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:text="Pick your name"
        android:textColor="#7a82a8"
        android:textSize="16sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⬆️⬇️ to choose row · ⬅️ ⏺ ➡️ to pick number"
        android:textColor="#4d96ff"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <!-- Kid selector -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/kid1"
            android:layout_width="160dp"
            android:layout_height="90dp"
            android:layout_margin="6dp"
            android:background="@drawable/btn_kid"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/kid2"
            android:layout_width="160dp"
            android:layout_height="90dp"
            android:layout_margin="6dp"
            android:background="@drawable/btn_kid"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/kid3"
            android:layout_width="160dp"
            android:layout_height="90dp"
            android:layout_margin="6dp"
            android:background="@drawable/btn_kid"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- PIN dots -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <TextView android:id="@+id/dot1" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="○" android:textColor="#4d96ff" android:textSize="42sp" android:layout_margin="6dp"/>
        <TextView android:id="@+id/dot2" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="○" android:textColor="#4d96ff" android:textSize="42sp" android:layout_margin="6dp"/>
        <TextView android:id="@+id/dot3" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="○" android:textColor="#4d96ff" android:textSize="42sp" android:layout_margin="6dp"/>
        <TextView android:id="@+id/dot4" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="○" android:textColor="#4d96ff" android:textSize="42sp" android:layout_margin="6dp"/>
    </LinearLayout>

    <!-- Row-based numpad -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Row 0: 1 2 3 -->
        <LinearLayout
            android:id="@+id/row0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp"
            android:layout_margin="4dp"
            android:background="@drawable/row_normal">
            <TextView android:id="@+id/r0c0" android:layout_width="80dp" android:layout_height="70dp"
                android:gravity="center" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:layout_margin="4dp"
                android:background="@drawable/cell_normal"/>
            <TextView android:id="@+id/r0c1" android:layout_width="80dp" android:layout_height="70dp"
                android:gravity="center" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:layout_margin="4dp"
                android:background="@drawable/cell_normal"/>
            <TextView android:id="@+id/r0c2" android:layout_width="80dp" android:layout_height="70dp"
                android:gravity="center" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:layout_margin="4dp"
                android:background="@drawable/cell_normal"/>
        </LinearLayout>

        <!-- Row 1: 4 5 6 -->
        <LinearLayout
            android:id="@+id/row1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp"
            android:layout_margin="4dp"
            android:background="@drawable/row_normal">
            <TextView android:id="@+id/r1c0" android:layout_width="80dp" android:layout_height="70dp"
                android:gravity="center" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:layout_margin="4dp"
                android:background="@drawable/cell_normal"/>
            <TextView android:id="@+id/r1c1" android:layout_width="80dp" android:layout_height="70dp"
                android:gravity="center" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:layout_margin="4dp"
                android:background="@drawable/cell_normal"/>
            <TextView android:id="@+id/r1c2" android:layout_width="80dp" android:layout_height="70dp"
                android:gravity="center" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:layout_margin="4dp"
                android:background="@drawable/cell_normal"/>
        </LinearLayout>

        <!-- Row 2: 7 8 9 -->
        <LinearLayout
            android:id="@+id/row2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp"
            android:layout_margin="4dp"
            android:background="@drawable/row_normal">
            <TextView android:id="@+id/r2c0" android:layout_width="80dp" android:layout_height="70dp"
                android:gravity="center" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:layout_margin="4dp"
                android:background="@drawable/cell_normal"/>
            <TextView android:id="@+id/r2c1" android:layout_width="80dp" android:layout_height="70dp"
                android:gravity="center" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:layout_margin="4dp"
                android:background="@drawable/cell_normal"/>
            <TextView android:id="@+id/r2c2" android:layout_width="80dp" android:layout_height="70dp"
                android:gravity="center" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:layout_margin="4dp"
                android:background="@drawable/cell_normal"/>
        </LinearLayout>

        <!-- Row 3: DEL 0 OK -->
        <LinearLayout
            android:id="@+id/row3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp"
            android:layout_margin="4dp"
            android:background="@drawable/row_normal">
            <TextView android:id="@+id/r3c0" android:layout_width="80dp" android:layout_height="70dp"
                android:gravity="center" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#ff6b6b" android:layout_margin="4dp"
                android:background="@drawable/cell_normal"/>
            <TextView android:id="@+id/r3c1" android:layout_width="80dp" android:layout_height="70dp"
                android:gravity="center" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:layout_margin="4dp"
                android:background="@drawable/cell_normal"/>
            <TextView android:id="@+id/r3c2" android:layout_width="80dp" android:layout_height="70dp"
                android:gravity="center" android:textSize="26sp" android:textStyle="bold"
                android:textColor="#6bcb77" android:layout_margin="4dp"
                android:background="@drawable/cell_normal"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
