<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="6dp"
    android:background="#161929"
    android:gravity="center_vertical">

    <TextView android:id="@+id/kidEmoji"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="32sp" android:layout_marginRight="14dp"/>

    <LinearLayout
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">

        <TextView android:id="@+id/kidName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>

        <TextView android:id="@+id/kidTime"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#7a82a8" android:textSize="14sp"/>

        <ProgressBar android:id="@+id/kidProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="6dp"
            android:layout_marginTop="4dp" android:max="100"/>
    </LinearLayout>

    <Button android:id="@+id/kidReset"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Reset"/>
</LinearLayout>
